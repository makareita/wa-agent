# Номер Twilio Sandbox (обычно один и тот же для всех, но проверь у себя в консоли)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Порт сервера (Railway/Render подставят свой автоматически)
PORT=3000
